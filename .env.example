# Magnet Gateway — Environment Variables

# LLM Provider — at least one is required
OPENAI_API_KEY=sk-xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx
GEMINI_API_KEY=xxxxx

# Auth & Storage
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxxx
REDIS_URL=redis://localhost:6379

# Qdrant
QDRANT_URL=https://xxx.qdrant.io
QDRANT_API_KEY=xxxxx

# neo4j
NEO4J_URL=bolt://localhost:7687
NEO4J_AUTH=neo4j/password

# Enterprise / On-Premise (BYOK — Bring Your Own Key)
# For self-hosted deployments, set your own LLM API keys here.
# No data leaves your infrastructure. All behavioral memory stays on your Redis.
#
# When using the Python SDK directly:
#   from magnet import BehavioralMemory
#   memory = BehavioralMemory(
#       openai_api_key="sk-...",   # Your key — never sent to Magnet servers
#       redis_client=your_redis,
#   )