# Magnet Gateway — Environment Variables

# LLM Provider — at least one is required
OPENAI_API_KEY=sk-xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx
GEMINI_API_KEY=xxxxx

# Auth & Storage
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxxx
REDIS_URL=redis://localhost:6379

# Hosted HTTP MCP mode (agent-magnet-http) — Postgres for api_keys/memory/usage_events
MAGNET_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/magnet

# Dashboard API auth (agent-magnet-http /api/keys, /api/usage, /api/memory) —
# verifies the website's Supabase session JWT.
# Most projects (legacy shared-secret signing, HS256): set SUPABASE_JWT_SECRET
# from Project Settings > API > JWT Secret.
# Projects on Supabase's newer asymmetric signing keys (RS256/ES256): set
# SUPABASE_PROJECT_URL instead — the JWKS is fetched from it. Both can be set;
# the token's own alg header picks which path verifies it.
SUPABASE_PROJECT_URL=https://xxxxx.supabase.co
SUPABASE_JWT_SECRET=xxxxx

# Comma-separated origins allowed to call the dashboard API above. Defaults
# to https://agentmagnet.app,https://www.agentmagnet.app + localhost dev
# ports if unset.
MAGNET_CORS_ORIGINS=https://agentmagnet.app,https://www.agentmagnet.app,http://localhost:5173,http://localhost:5001

# Encrypts BYO team redis_urls at rest (Postgres teams.redis_url_enc).
# Generate once with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this key makes existing encrypted redis_urls unreadable — treat it
# like any other long-lived secret.
MAGNET_ENCRYPTION_KEY=

# Usage caps shown on the dashboard's Usage tab (GET /api/usage) and, for
# memories/team-sync, actually enforced (see mcp_server._memory_cap_check
# and team_permissions.check_team_permission). Personal sync_cap is
# display-only for now — all defaults below match if unset.
# MAGNET_FREE_MEMORY_CAP=1000
# MAGNET_PAID_MEMORY_CAP=50000
# MAGNET_FREE_SYNC_CAP=1000
# MAGNET_PAID_SYNC_CAP=50000
# MAGNET_TEAM_SYNC_CAP=50000
# MAGNET_ENFORCE_SYNC_CAP=false
# MAGNET_RATE_LIMIT_PER_MIN=60

# Qdrant
QDRANT_URL=https://xxx.qdrant.io
QDRANT_API_KEY=xxxxx

# neo4j
NEO4J_URL=bolt://localhost:7687
NEO4J_AUTH=neo4j/password

# Enterprise / On-Premise (BYOK — Bring Your Own Key)
# For self-hosted deployments, set your own LLM API keys here.
# No data leaves your infrastructure. All behavioral memory stays on your Redis.
#
# When using the Python SDK directly:
#   from magnet import BehavioralMemory
#   memory = BehavioralMemory(
#       openai_api_key="sk-...",   # Your key — never sent to Magnet servers
#       redis_client=your_redis,
#   )